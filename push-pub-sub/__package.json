{
  "name": "@nu-art/push-pub-sub",
  "version": "$THUNDERSTORM_VERSION",
  "description": "push-pub-sub",
  "keywords": [
    "TacB0sS",
    "express",
    "infra",
    "nu-art",
    "push-pub-sub",
    "thunderstorm",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:nu-art-js/push-pub-sub.git"
  },
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": true
  },
  "license": "Apache-2.0",
  "author": "TacB0sS",
  "scripts": {
    "build": "tsc -b -f"
  },
  "dependencies": {
    "@nu-art/thunderstorm": "$THUNDERSTORM_DEP_VERSION",
    "@nu-art/ts-styles": "$THUNDERSTORM_DEP_VERSION",
    "@nu-art/permissions": "$THUNDERSTORM_DEP_VERSION",
    "@nu-art/ts-common": "$THUNDERSTORM_DEP_VERSION",
    "@nu-art/firebase": "$THUNDERSTORM_DEP_VERSION",
    "@nu-art/user-account": "$THUNDERSTORM_DEP_VERSION",
    "firebase": "$FIREBASE_PKG_VERSION",
    "firebase-admin": "$FIREBASE_ADMIN_PKG_VERSION",
    "moment": "$MOMENT_PKG_VERSION",
    "react": "$REACT_PKG_VERSION"
  },
  "devDependencies": {
    "@types/react": "$REACT_TYPES_VERSION"
  },
  "unitConfig": {
    "type": "typescript-lib"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js"
    }
  }
}