## When building a custom transfer UI

Do not use the `TransferBubble`. Instead, implement `OnFileTransferStateChanged` in your component:

```typescript
import {ComponentSync} from '@nu-art/thunder-widgets';
import {FileTransferState, OnFileTransferStateChanged} from '@nu-art/file-upload-frontend';

export class MyCustomTransferUI
	extends ComponentSync<Props, State>
	implements OnFileTransferStateChanged {

	__onFileTransferStateChanged = (state: FileTransferState) => {
		// state.direction: 'upload' | 'download'
		// state.phase: 'requesting' | 'uploading' | 'confirming' | 'preparing' | 'downloading' | 'completed' | 'failed'
		// state.progress: 0..1 (during 'uploading' or 'downloading')
		// state.error: string (when 'failed')
		// state.asset: DB_Asset (when 'completed' or 'failed')
		// state.assetId: string (after request resolves)
		// state.name: string (always present)
	};
}
```

Upload phases: `requesting` → `uploading` → `confirming` → `completed` | `failed`
Download phases: `requesting` → `preparing` → `downloading` → `completed` | `failed`

