## When swapping the storage backend

The default is GCS via `StorageAdapter_GCS`. To use a different storage provider, implement `StorageAdapter` and set it before module init:

```typescript
import {ModuleBE_FileUpload} from '@nu-art/file-upload-backend';
import {StorageAdapter} from '@nu-art/file-upload-shared';

class StorageAdapter_S3 implements StorageAdapter {
	async getWriteSignedUrl(path: string, contentType: string, expiresMs: number): Promise<string> { /* ... */ }
	async getReadSignedUrl(path: string, expiresMs: number): Promise<string> { /* ... */ }
	async getFileMetadata(path: string): Promise<StorageFileMetadata> { /* ... */ }
	async readFile(path: string): Promise<Buffer> { /* ... */ }
	async deleteFile(path: string): Promise<void> { /* ... */ }
	async fileExists(path: string): Promise<boolean> { /* ... */ }
	makePublic?(path: string): Promise<void> { /* ... */ }
}

// Before init — e.g. in app setup:
ModuleBE_FileUpload.setStorageAdapter(new StorageAdapter_S3());
```

If no adapter is set before init, GCS is used automatically.

