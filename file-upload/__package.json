{
  "name": "@nu-art/file-upload",
  "version": "$THUNDERSTORM_VERSION",
  "description": "File Uploader - Express & Typescript based backend framework",
  "keywords": [
    "TacB0sS",
    "infra",
    "nu-art",
    "storm",
    "thunderstorm",
    "typescript"
  ],
  "homepage": "https://github.com/nu-art-js/file-upload",
  "bugs": {
    "url": "https://github.com/nu-art-js/file-upload/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:nu-art-js/file-upload.git"
  },
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": true
  },
  "license": "Apache-2.0",
  "author": "TacB0sS",
  "files": [
    "**/*"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@nu-art/firebase": "?",
    "@nu-art/ts-styles": "?",
    "@nu-art/push-pub-sub": "?",
    "@nu-art/permissions": "?",
    "@nu-art/user-account": "?",
    "@nu-art/thunderstorm": "?",
    "@nu-art/ts-common": "?",
    "@google-cloud/common": "$GOOGLE_CLOUD_COMMON",
    "@google-cloud/storage": "$GOOGLE_CLOUD_STORAGE",
    "@google-cloud/firestore": "$GOOGLE_CLOUD_FIRESTORE",
    "react": "$REACT_PKG_VERSION",
    "jszip": "^3.2.2",
    "express": "$EXPRESS_PKG_VERSION",
    "firebase": "$FIREBASE_PKG_VERSION",
    "firebase-admin": "$FIREBASE_ADMIN_PKG_VERSION",
    "firebase-functions": "$FIREBASE_FUNCTIONS_PKG_VERSION",
    "google-auth-library": "$GOOGLE_AUTHLIB_VERSION",
    "file-type": "^21.0.0"
  },
  "devDependencies": {
    "@types/react": "$REACT_TYPES_VERSION",
    "@types/compression": "^1.0.1",
    "@types/express": "$EXPRESS_TYPES_VERSION"
  },
  "unitConfig": {
    "type": "typescript-lib"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js"
    }
  }
}