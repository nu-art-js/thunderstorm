    "file-type": "^21.0.0"
  },
  "devDependencies": {
    "@nu-art/testalot": "?",
    "@nu-art/google-services-backend": "?"
  },
  "unitConfig": {
    "type": "typescript-lib"
  },
  "type": "module",
  "exports": {
    ".": {
