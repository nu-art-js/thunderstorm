  "files": [
    "**/*"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@nu-art/file-upload-shared": "?",
    "@nu-art/firebase-backend": "?",
    "@nu-art/api-types": "?",
