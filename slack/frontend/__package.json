    "storm",
    "thunderstorm",
    "typescript"
  ],
  "homepage": "https://github.com/nu-art-js/storm",
  "bugs": {
    "url": "https://github.com/nu-art-js/storm/issues"
  },
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": true
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:nu-art-js/storm.git"
  },
  "license": "Apache-2.0",
