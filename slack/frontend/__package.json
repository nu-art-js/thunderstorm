  "files": [
    "**/*"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@nu-art/slack-shared": "?",
    "@nu-art/thunderstorm-frontend": "?",
    "@nu-art/thunderstorm-shared": "?",
    "@nu-art/ts-common": "?",
    "@slack/events-api": "^2.3.0",
    "@slack/web-api": "7.9.3",
    "firebase": "?",
    "firebase-admin": "?",
    "firebase-functions": "?",
    "google-auth-library": "?",
    "moment": "?",
    "react": "?",
    "react-dom": "?",
    "react-router-dom": "?"
  },
  "devDependencies": {
    "@types/react": "?",
    "@types/react-dom": "?",
    "@types/react-router": "?",
    "@types/react-router-dom": "?"
  },
  "unitConfig": {
    "type": "typescript-lib"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
