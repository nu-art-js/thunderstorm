  "dependencies": {
    "@nu-art/jira-shared": "?",
    "@nu-art/thunder-db-api-backend": "?",
    "@nu-art/thunder-db-api-shared": "?",
    "@nu-art/ts-common": "?",
    "body-parser": "^1.18.3",
    "compression": "^1.7.4",
    "express": "?",
    "firebase-admin": "?",
    "moment": "?",
    "request": "^2.88.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.2",
    "@types/express": "?",
    "@types/js-base64": "^2.3.1",
    "@types/request": "^2.48.3",
    "@types/saml2-js": "^1.6.8"
