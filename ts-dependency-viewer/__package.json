{
  "name": "@nu-art/ts-dependency-viewer",
  "version": "$THUNDERSTORM_VERSION",
  "description": "ts-dependency-viewer - Express & Typescript based backend framework",
  "keywords": [
    "TacB0sS",
    "infra",
    "nu-art",
    "thunderstorm",
    "typescript",
    "ts-dependency-viewer"
  ],
  "homepage": "https://github.com/nu-art-js/thunderstorm",
  "bugs": {
    "url": "https://github.com/nu-art-js/thunderstorm/issues"
  },
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": true
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:nu-art-js/thunderstorm.git"
  },
  "license": "Apache-2.0",
  "author": "TacB0sS",
  "files": [
    "**/*"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@nu-art/ts-common": "$THUNDERSTORM_DEP_VERSION",
    "@nu-art/thunderstorm": "$THUNDERSTORM_DEP_VERSION",
    "firebase": "$FIREBASE_PKG_VERSION",
    "firebase-admin": "$FIREBASE_ADMIN_PKG_VERSION",
    "firebase-functions": "$FIREBASE_FUNCTIONS_PKG_VERSION",
    "react": "$REACT_PKG_VERSION",
    "compression": "^1.7.4",
    "d3": "$D3_VERSION",
    "d3-graphviz": "$D3_GRAPHVIZ_VERSION",
    "d3-selection": "$D3_SELECTION_VERSION",
    "ts-graphviz": "$TS_GRAPHVIZ_VERSION"
  },
  "devDependencies": {
    "@types/react": "$REACT_TYPES_VERSION",
    "@types/chai": "^4.3.4",
    "@types/mocha": "^10.0.1",
    "@types/d3": "^7.4.0",
    "@types/d3-graphviz": "^2.6.7"
  },
  "unitConfig": {
    "type": "typescript-lib"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js"
    }
  }
}