  },
  "devDependencies": {
    "@types/saml2-js": "^1.6.8",
    "chai": "^5.1.2",
    "@types/chai": "^5.0.1",
    "@types/mocha": "^10.0.10",
    "ts-mocha": "^10.1.0"
