## 7. React component structure

### Class structure

```tsx
export class Editor_DiseaseProfile extends ComponentSync<Props, State>
  implements DispatcherInterface<DispatcherType_DiseaseProfile> {

  // ######################## Lifecycle ########################

  protected deriveStateFromProps(nextProps: Props, state: State) { ... }

  // ######################## Logic ########################

  private someLogicMethod = () => { ... };

  // ######################## Render ########################

  render() { return <LL_V_L className={'e__disease-profile'}>{...}</LL_V_L>; }

  private renderHeader = () => { ... };
  private renderForm = () => { ... };
}
```

Section comments (`// ####`) are part of the standard — keep them. They create fast navigation landmarks.

### Props and State type definitions

Always define `Props` and `State` as local types at the top of the file. Never use inline object types in the class signature.

```tsx
type Props = {
  workHubItem: WorkHubItem<WorkHubArgs_DiseaseProfile>;
  renderArgs: WorkHubArgs_DiseaseProfile;
  tabId: string;
};

type State = {
  editable: EditableDBItemV3<DBProto_DiseaseProfile>;
  renderArgs: WorkHubArgs_DiseaseProfile;
};
```

### deriveStateFromProps

Use for all prop-to-state mapping. Do not use `componentDidMount` + manual `setState` for initialization.

```tsx
protected deriveStateFromProps(nextProps: Props, state: State) {
  state.tabId = nextProps.tabId;
  state.renderArgs = nextProps.renderArgs;
  if (state.tabId !== this.state?.tabId)
    state.editable = this.buildEditable(state.renderArgs.diseaseProfileId);
  return state;
}
```

