  "scripts": {
    "build": "tsc",
    "launch": "tsc --watch & firebase emulators:start --import=../.trash/data --export-on-exit",
    "serve": "cd .. && bash ./build-and-install.sh -lb -nb"
  },
  "dependencies": {
    "@app/app-shared": "?",
    "@nu-art/bug-report": "?",
    "@nu-art/jira": "?",
    "@nu-art/file-upload": "?",
    "@nu-art/firebase": "?",
    "@nu-art/google-services": "?",
    "@nu-art/live-docs": "?",
    "@nu-art/permissions": "?",
    "@nu-art/push-pub-sub": "?",
    "@nu-art/slack": "?",
    "@nu-art/thunderstorm": "?",
    "@nu-art/ts-common": "?",
    "@nu-art/user-account": "?",
    "firebase": "?",
    "firebase-admin": "?",
    "firebase-functions": "?",
    "firebase-functions-test": "^0.1.6",
    "@slack/web-api": "?",
    "body-parser": "^1.18.3",
    "file-type": "^16.3.0",
    "compression": "^1.7.4",
    "debug": "^3.1.0",
    "express": "?",
    "js-base64": "^2.5.1",
    "module-alias": "^2.2.0",
    "moment": "?"
  },
  "devDependencies": {
    "@types/body-parser": "^1.17.0",
    "@types/debug": "^4.1.2",
    "@types/express": "?",
    "@types/js-base64": "^2.3.1",
    "@types/request": "^2.48.3",
    "@types/saml2-js": "^1.6.8"
  },
  "engines": {
    "node": "22"
  },
  "_moduleAliases": {
    "@consts": "dist/consts",
    "@modules": "dist/modules",
    "@shared": "dist/app-shared"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js"
    }
  }
}