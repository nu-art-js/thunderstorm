# GCP Configuration
GCP_PROJECT_ID=your-project-id
ARTIFACT_REGISTRY_REGION=us-central1
ARTIFACT_REGISTRY_REPOSITORY=firebase-functions
# Using manual_ prefix to avoid collisions with other test images
IMAGE_NAME=manual-test-function
IMAGE_TAG=v1.0.0
DEPLOY_REGION=us-central1

# Function Names (comma-separated)
# Using manual_ prefix to avoid collisions with other test functions
FUNCTION_NAMES=manual_hello,manual_goodbye

# Optional: Deployment ID for tracking
DEPLOYMENT_ID=manual-test-$(date +%s)

