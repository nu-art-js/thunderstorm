{
  "name": "@nu-art/analytics-frontend",
  "version": "$THUNDERSTORM_VERSION",
  "description": "Analytics Frontend",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc"
  },
  "publishConfig": {
