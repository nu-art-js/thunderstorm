{
  "name": "@nu-art/analytics-shared",
  "version": "$THUNDERSTORM_VERSION",
  "description": "Analytics Shared",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc"
  },
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": true
  },
  "dependencies": {
    "@nu-art/ts-common": "?",
    "@nu-art/thunderstorm": "?"
  },
  "devDependencies": {},
  "private": false,
  "bai": {
    "label": "Analytics Shared",
    "pathToConfig": "./config.ts",
    "customTSConfig": false
  },
  "unitConfig": {
    "type": "typescript-lib"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js"
    }
  }
}