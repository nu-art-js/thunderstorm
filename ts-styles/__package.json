{
  "name": "@nu-art/ts-styles",
  "version": "$THUNDERSTORM_VERSION",
  "author": "nu-art",
  "description": "Styles by Cipher",
  "type": "module",
  "scripts": {
    "build": "tsc"
  },
  "license": "ISC",
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": true
  },
  "dependencies": {
    "@nu-art/ts-common": "?",
    "react": "$REACT_PKG_VERSION"
  },
  "devDependencies": {
    "@types/react": "$REACT_TYPES_VERSION"
  },
  "unitConfig": {
    "type": "typescript-lib"
  },
  "contributors": [
    {
      "name": "cipher_il",
      "url": "https://www.npmjs.com/~cipher_il"
    }
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "sass": "./index.scss"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js",
      "sass": "./*.scss"
    }
  }
}