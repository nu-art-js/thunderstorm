{
  "name": "@nu-art/ts-common",
  "version": "{{THUNDERSTORM_VERSION}}",
  "description": "Core TypeScript infrastructure library for building modular applications with lifecycle management, logging, validation, and utilities",
  "type": "module",
  "keywords": [
    "typescript",
    "infrastructure",
    "module-system",
    "lifecycle-management",
    "logging",
    "validation",
    "utilities",
    "nu-art",
    "thunderstorm",
    "ts-common",
    "framework",
    "application-framework"
  ],
  "homepage": "https://github.com/nu-art-js/thunderstorm",
  "bugs": {
    "url": "https://github.com/nu-art-js/thunderstorm/issues?q=is%3Aissue+label%3Ats-common"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:nu-art-js/thunderstorm.git",
    "directory": "_thunderstorm/ts-common"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "license": "Apache-2.0",
  "author": "TacB0sS",
  "scripts": {
    "build": "tsc",
    "typedocs": "typedoc --options typedoc.json",
    "run-tests": "ts-mocha --timeout 50000 -p src/test/tsconfig.json src/test/run-all-tests.ts"
  },
  "dependencies": {
    "@nu-art/testalot": "?",
    "@nu-art/logger": "?",
    "fast-csv": "^5.0.2",
    "export-to-csv": "0.2.1",
    "moment": "?",
    "node-forge": "^1.2.1",
    "uuid": "^9.0.0",
    "csv-parser": "^2.3.3",
    "jose": "?"
  },
  "devDependencies": {
    "@types/minimatch": "^5.1.2",
    "@types/node-forge": "^1.0.0"
  },
  "unitConfig": {
    "type": "typescript-lib"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./utils": {
      "types": "./utils-public-exports.d.ts",
      "import": "./utils-public-exports.js"
    },
    "./mem-storage": {
      "types": "./mem-storage/MemStorage.d.ts",
      "import": "./mem-storage/MemStorage.js"
    },
    "./testing": {
      "types": "./testing.d.ts",
      "import": "./testing.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js"
    }
  }
}