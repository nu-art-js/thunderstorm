    "@nu-art/thunderstorm-frontend": "?",
    "@nu-art/thunderstorm-shared": "?",
    "@nu-art/ts-common": "?",
    "@nu-art/user-account-frontend": "?",
    "@nu-art/user-account-shared": "?",
    "express": "?",
    "firebase": "?",
    "firebase-admin": "?",
    "firebase-functions": "?",
    "moment": "?",
    "react": "?",
    "react-dom": "?",
    "react-router-dom": "?"
  },
  "devDependencies": {
    "@types/react": "?",
    "@types/express": "?",
    "@types/history": "^4.7.2",
    "@types/request": "^2.48.1"
  },
  "unitConfig": {
    "type": "typescript-lib"
  },
  "type": "module",
  "exports": {
