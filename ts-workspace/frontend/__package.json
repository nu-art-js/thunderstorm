  "version": "$THUNDERSTORM_VERSION",
  "description": "TS Workspace Frontend",
  "keywords": [
    "TacB0sS",
    "express",
    "infra",
    "live-docs",
    "nu-art",
    "thunderstorm",
    "typescript"
  ],
