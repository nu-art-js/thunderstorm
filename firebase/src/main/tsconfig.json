{
  "compilerOptions": {
    "target": "es2022",
    "jsx": "react",
    "lib": [
      "es2022",
      "dom"
    ],
    "declaration": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "module": "commonjs",
    "sourceMap": true,
    "strict": true
  },
  "esModuleInterop": true,
  "module": "ES2023"
}
