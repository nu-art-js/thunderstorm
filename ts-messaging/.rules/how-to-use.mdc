## When subscribing to messaging events

### Topic updates

```typescript
import {ComponentSync} from '@nu-art/thunder-widgets';
import type {OnTopicsUpdated} from '@nu-art/ts-messaging-frontend';

export class MyComponent
	extends ComponentSync<Props, State>
	implements OnTopicsUpdated {

	__onTopicsUpdated = () => {
		// Topics changed — re-render
		this.forceUpdate();
	};
}
```

### Message updates

```typescript
import type {OnMessagesUpdated} from '@nu-art/ts-messaging-frontend';

export class MyComponent
	extends ComponentSync<Props, State>
	implements OnMessagesUpdated {

	__onMessagesUpdated = () => {
		// Messages changed — refresh list
		this.forceUpdate();
	};
}
```

