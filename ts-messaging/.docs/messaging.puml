@startuml
skinparam linetype ortho

rectangle "App Layer" {
	entity "Anchor Entity" as anchor {
		_id: UniqueId
		dbKey: string
	}
	note bottom of anchor: Any DB entity that\nneeds a conversation\n(task, chat-room, etc.)
}

rectangle "ts-messaging" {
	entity "DB_Topic" as topic {
		_id: UniqueId
		anchor: DBPointer {dbKey, id}
		__access: DocumentAccess
	}
	note right of topic
		Unique: [anchor.dbKey, anchor.id]
		One topic per anchor entity
	end note

	entity "DB_Message" as msg {
		_id: UniqueId
		topicId: UniqueId
		parentMessageId?: UniqueId
		text?: string
		attachments?: AssetRef[]
		_auditorId: string
		__access: DocumentAccess
	}
	note right of msg
		Must have text or attachments (or both)
		_auditorId auto-set from session
		parentMessageId enables threading
	end note
}

rectangle "file-upload" {
	entity "DB_Asset" as asset {
		_id: UniqueId
		name: string
		mimeType: string
		key: string
	}
}

rectangle "Permissions" {
	entity "AccessGroup" as ag {
		Read / Write / Delete / Admin
	}
	note bottom of ag
		Static groups now
		Dynamic per-topic groups later
	end note
}

anchor ||--|| topic : "anchors (1:1)"
topic ||--o{ msg : "contains"
msg ||--o{ msg : "thread replies\n(parentMessageId)"
msg }o--o{ asset : "attachments\n(AssetRef.assetId)"
ag ..> topic : "gates access"
ag ..> msg : "inherits from topic"
@enduml
